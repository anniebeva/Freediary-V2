# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/freediary_db

# Security Settings
SECRET_KEY=your_very_long_and_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
DEBUG=False
ENVIRONMENT=development

# Authentication
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional External Services
# SENTRY_DSN=your_sentry_dsn_here
# LOGGING_LEVEL=INFO

# JWT Configuration
JWT_SECRET=another_secure_random_key
JWT_REFRESH_SECRET=yet_another_secure_random_key

# Optional Database Credentials (if not using connection string)
DB_HOST=localhost
DB_PORT=5432
DB_USER=freediary_user
DB_PASSWORD=your_secure_password
DB_NAME=freediary_db